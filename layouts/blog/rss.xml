{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>jamessmithies.org/blog RSS</title>
    <link>{{ .Permalink }}</link>
    <description>Updates on blog posts on jamessmithies.org.</description>
    <atom:link href="{{ .Permalink }}feed/" rel="self"></atom:link>
    <language>en-gb</language>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    {{- range first 100 (where .Site.RegularPages "Section" "blog") }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <description>{{ if .Params.excerpt }}{{ .Params.excerpt | html }}{{ else }}{{ .Summary | html }}{{ end }}</description>
      <guid>{{ .Permalink }}</guid>
    </item>
    {{- end }}
  </channel>
</rss>
